<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="Current" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Editor-Debug|x64'">
    <LocalDebuggerWorkingDirectory>..\Build\bin\Editor-Debug-windows-x86_64\$(ProjectName)</LocalDebuggerWorkingDirectory>
    <DebuggerFlavor>WindowsLocalDebugger</DebuggerFlavor>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Editor-Release|x64'">
    <LocalDebuggerWorkingDirectory>..\Build\bin\Editor-Release-windows-x86_64\$(ProjectName)</LocalDebuggerWorkingDirectory>
    <DebuggerFlavor>WindowsLocalDebugger</DebuggerFlavor>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Game-Debug|x64'">
    <LocalDebuggerWorkingDirectory>..\Build\bin\Game-Debug-windows-x86_64\$(ProjectName)</LocalDebuggerWorkingDirectory>
    <DebuggerFlavor>WindowsLocalDebugger</DebuggerFlavor>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Game-Release|x64'">
    <LocalDebuggerWorkingDirectory>..\Build\bin\Game-Release-windows-x86_64\$(ProjectName)</LocalDebuggerWorkingDirectory>
    <DebuggerFlavor>WindowsLocalDebugger</DebuggerFlavor>
  </PropertyGroup>
</Project>